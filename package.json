    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "axios": "^1.18.1",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "pg": "^8.22.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.12",
        "@types/pg": "^8.20.0",
        "jest": "^29.7.0",
        "prisma": "^7.8.0",
        "ts-jest": "^29.1.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5"
    }
}
