{
    "name": "consultation-booking-system",
    "version": "1.0.0",
    "description": "Scalable Consultation Booking Backend",
    "main": "dist/app.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/app.js",
        "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
